<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:id="@+id/mpHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/divider_dark"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/mpTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/nova_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/mpHandle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/mpProvider"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary_dark"
        android:textSize="12sp"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="14dp"
        app:layout_constraintTop_toBottomOf="@id/mpTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/modelList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/mpProvider"
        app:layout_constraintHeight_max="380dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
