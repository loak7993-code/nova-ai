<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_dark"
        android:title="@string/settings"
        android:titleTextColor="@color/text_primary_dark"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/cancel"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_api_header"
                android:textColor="@color/nova_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_api_base"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/apiBaseUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary_dark"
                android:textColorHint="@color/text_secondary_dark"
                android:textSize="15sp"
                android:inputType="textUri"
                android:singleLine="true"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_api_key"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/apiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary_dark"
                android:textColorHint="@color/text_secondary_dark"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_model"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <AutoCompleteTextView
                android:id="@+id/modelSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary_dark"
                android:textSize="15sp"
                android:inputType="none"
                android:padding="14dp"
                android:dropDownVerticalOffset="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_behavior_header"
                android:textColor="@color/nova_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_system_prompt"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/systemPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary_dark"
                android:textSize="15sp"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_temperature"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/temperatureValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nova_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/temperatureSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="20"
                android:progressTint="@color/nova_primary"
                android:thumbTint="@color/nova_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_stream"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_stream_helper"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Switch
                    android:id="@+id/streamToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_search_header"
                android:textColor="@color/nova_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_search_url"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/searchUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary_dark"
                android:textColorHint="@color/text_secondary_dark"
                android:hint="http://your-searxng:8888"
                android:textSize="15sp"
                android:inputType="textUri"
                android:singleLine="true"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pref_search_url_helper"
                android:textColor="@color/text_secondary_dark"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/clearAllButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/clear_all"
                android:textColor="@color/error_red"
                android:background="@android:color/transparent"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:paddingStart="0dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/save"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_send_button_selector" />

</LinearLayout>
